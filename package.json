{
  "name": "trigr-server",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "typings": "dist/src/index.d.ts",
  "bin": {
    "ntms": "dist/src/index.js",
    "trigr-server": "dist/src/index.js"
  },
  "keywords": [
    "nodejs",
    "typescript"
  ],
  "author": "Bikrant J. Budhathoki",
  "license": "MIT",
  "scripts": {
    "bundle": "rimraf dist && esbuild --outdir=dist --sourcemap --bundle --platform=node --target=node20.10.0 ./src/index.ts",
    "compile": "tsc",
    "compile:watch": "tsc -w",
    "dev": "nodemon --watch src --watch test --ext ts,json --exec 'yarn bundle && yarn start'",
    "debug": "yarn bundle && node --enable-source-maps --inspect-brk ./dist/index.js",
    "debug:test": "node --inspect-brk ./node_modules/.bin/jest --runInBand .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "start": "node --enable-source-maps ./dist/index.js",
    "test": "jest --runInBand .",
    "migrate": "node-pg-migrate create ",
    "db:push": "dotenv -e .env -- node-pg-migrate up",
    "db:rollback": "dotenv -e .env -- node-pg-migrate up"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "7.28.5",
    "@jest/globals": "29.7.0",
    "@tsconfig/node20": "20.1.9",
    "@types/express": "^5",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.39",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "0.21.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "jest": "29.7.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "rimraf": "5.0.10",
    "typescript": "5.9.3"
  },
  "packageManager": "yarn@4.2.2",
  "dependencies": {
    "express": "^5.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0"
  }
}
