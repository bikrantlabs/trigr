{
  "name": "trigr-server",
  "version": "1.0.0",
  "main": "dist/src/server.js",
  "typings": "dist/src/server.d.ts",
  "bin": {
    "ntms": "dist/src/server.js",
    "trigr-server": "dist/src/server.js"
  },
  "keywords": [
    "nodejs",
    "typescript"
  ],
  "author": "Bikrant J. Budhathoki",
  "license": "MIT",
  "scripts": {
    "bundle": "rimraf dist && esbuild --outdir=dist --sourcemap --bundle --platform=node --target=node20.10.0 ./src/server.ts",
    "compile": "tsc",
    "compile:watch": "tsc -w",
    "dev": "nodemon --watch src --watch test --ext ts,json --exec 'yarn bundle && node --enable-source-maps ./dist/server.js | pino-pretty'",
    "debug": "yarn bundle && node --enable-source-maps --inspect-brk ./dist/server.js",
    "debug:test": "node --inspect-brk ./node_modules/.bin/jest --runInBand .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "start": "node --enable-source-maps ./dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "node-pg-migrate create ",
    "db:push": "dotenv -e .env -- node-pg-migrate up",
    "db:rollback": "dotenv -e .env -- node-pg-migrate down"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "7.28.5",
    "@jest/globals": "29.7.0",
    "@tsconfig/node20": "20.1.9",
    "@types/cors": "^2",
    "@types/express": "^5.0.6",
    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "esbuild": "0.21.3",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "jest": "29.7.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.3",
    "rimraf": "5.0.10",
    "supertest": "^7.2.2",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "yarn@4.2.2",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  }
}
